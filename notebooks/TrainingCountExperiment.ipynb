   "source": [
    "## Launch and Monitor Training Jobs"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 33,
   "id": "11",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Creating 2 training jobs.\n"
     ]
    }
   ],
   "source": [
    "# Create all JobNames and Parameter Configs\n",
    "# Use SageMaker's name_from_base function to ensure name is 1) less than 63 characters and 2) has a unique ending\n",
    "jobs_to_run = []\n",
    "for count in training_counts:\n",
